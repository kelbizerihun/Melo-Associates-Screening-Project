# Obtain a secret key from Google AI Developers and set it here.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The public URL where this full-stack application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
